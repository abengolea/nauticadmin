# Firebase - NauticAdmin
# Copiar a .env.local y ajustar si es necesario. No commitear .env.local
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBggeQWGSw0MWuaj9hgSaXl8oJU8fA7rlA
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=nauticadmin.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=nauticadmin
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=nauticadmin.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=152426823166
NEXT_PUBLIC_FIREBASE_APP_ID=1:152426823166:web:872ffa50ce19e8e43814af

# URL base de la app (local: dev; producción: tu dominio o App Hosting)
NEXT_PUBLIC_APP_URL=http://localhost:9003

# Firebase Admin (API routes en local: mensualidades, pagos, etc.)
# 1. Firebase Console → Project settings → Service accounts → Generate new private key
# 2. Guardar el JSON como service-account.json en la raíz (está en .gitignore)
# 3. Verificar: node scripts/check-admin-creds.js
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Mercado Pago (para pagos online - configurar cuando aplique)
# MERCADOPAGO_CLIENT_ID=
# MERCADOPAGO_CLIENT_SECRET=

# Genkit / AI (opcional - para flows de IA)
# GEMINI_API_KEY=
# GEMINI_EXPENSE_MODEL=gemini-2.5-flash-lite  # Forzar modelo rápido para facturas (opcional)

# AFIP - Facturación con delegación ARCA (Notificas opera, emisor = náutica en Firestore)
#
# Certificados digitales: NOTIFICAS SRL (delegado). NO hace falta el cert de Yaguaron si
# la náutica delegó "Web Services de Facturación Electrónica" en ARCA.
# AFIP_CERT_PATH=./afip/certificado_prod.crt
# AFIP_KEY_PATH=./afip/privada_prod.key
# AFIP_CHAIN_PATH=./afip/chain_prod.pem
#
# CUIT emisor, pto vta y razón social: vienen de school.facturacion (EL YAGUARON SA 30714605522).
# AFIP_CUIT solo se usa en scripts sueltos (test-afip, emit-test-invoice); en Cobros usa Firestore.
# AFIP_CUIT=30693887743
# AFIP_PRODUCTION=true
# AFIP_PTO_VTA=6
# AFIP_CBTE_TIPO=6
